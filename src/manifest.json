{
  "manifest_version": 3,
  "name": "ChatGPT Companion",
  "version": "1.0.0",
  "description": "Understand, analyze, and discuss any webpage with ChatGPT in one click.",
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon_16.png",
      "32": "icons/icon_32.png"
    }
  },
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "commands": {
    "open-prompt-picker": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Open prompt template picker"
    }
  },
  "permissions": [
    "contextMenus",
    "sidePanel",
    "scripting",
    "storage",
    "tabs",
    "activeTab",
    "declarativeNetRequest",
    "identity",
    "identity.email"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "chatgpt-content.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "prompt-picker/index.html",
        "prompt-picker/index.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
